# ==============================
# Core runtime
# ==============================
PORT=5000
APP_URL=http://localhost:3000

# ==============================
# Database (Prisma)
# ==============================
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecommerce
DIRECT_URL=postgresql://postgres:password@localhost:5432/ecommerce

# ==============================
# Supabase
# ==============================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==============================
# SEPay (required for SEPay checkout)
# ==============================
SEPAY_ENV=sandbox
SEPAY_MERCHANT_CODE=your_sepay_merchant_code
SEPAY_SECRET_KEY=your_sepay_secret_key
SEPAY_PAYMENT_METHOD=BANK_TRANSFER
SEPAY_RETURN_URL=http://localhost:3000/profile/orders
# For local test, set this to your ngrok URL (see guide file below)
SEPAY_IPN_URL=https://your-ngrok-subdomain.ngrok-free.app/payment/ipn/sepay

# ==============================
# Optional gateways (only fill if you use them)
# ==============================
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/profile/orders
MOMO_IPN_URL=https://your-ngrok-subdomain.ngrok-free.app/payment/ipn/momo

ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_CALLBACK_URL=https://your-ngrok-subdomain.ngrok-free.app/payment/zalopay/callback
ZALOPAY_RETURN_URL=http://localhost:3000/profile/orders

# ==============================
# Optional integrations
# ==============================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/auth/facebook/callback

GEMINI_API_KEY=
