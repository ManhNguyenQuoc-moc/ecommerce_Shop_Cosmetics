model Image {
  id        String   @id @default(uuid())
  url       String
  altText   String?
  createdAt DateTime @default(now())

  productImages   ProductImage[]
  productVariants ProductVariant[]
  categories      Category[]
  brandsAsLogo    Brand[] @relation("BrandLogo")
  brandsAsBanner  Brand[] @relation("BrandBanner")
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  
  logoId      String?
  logo        Image?    @relation("BrandLogo", fields: [logoId], references: [id], onDelete: SetNull)
  
  bannerId    String?
  banner      Image?    @relation("BrandBanner", fields: [bannerId], references: [id], onDelete: SetNull)
  
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  
  imageId     String?
  image       Image?    @relation(fields: [imageId], references: [id], onDelete: SetNull)
  
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                String        @id @default(uuid())
  name              String
  slug              String        @unique
  short_description String?       @db.Text
  long_description  String?       @db.Text
  statusName        ProductStatus @default(NEW)
  price             Float         @default(0)
  salePrice         Float?
  rating            Float         @default(0)
  sold              Int           @default(0)
  specifications    Json?

  productImages     ProductImage[]

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  variants ProductVariant[]
  reviews  Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  imageId   String
  order     Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  image     Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([productId, imageId])
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  color String?
  size  String?
  
  imageId String?
  image   Image?  @relation(fields: [imageId], references: [id], onDelete: SetNull)

  price          Float
  salePrice      Float?
  stock_quantity Int    @default(0)

  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductStatus {
  BEST_SELLING
  TRENDING
  NEW
}
